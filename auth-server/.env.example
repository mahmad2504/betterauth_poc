AUTH_PORT=3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=better_auth
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Set to false if SMTP fails with "self-signed certificate" (common behind corporate proxies).
SMTP_TLS_REJECT_UNAUTHORIZED=false
# Optional. Leave empty to run the demo without Google sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Generated OAuth client credentials for distribution only.
# Do not edit: they are not auth-server configuration values.
# Rotate clients through Better Auth, then run the bootstrap again.
APP_ONE_OIDC_CLIENT_ID=
APP_ONE_OIDC_CLIENT_SECRET=
APP_TWO_OIDC_CLIENT_ID=
APP_TWO_OIDC_CLIENT_SECRET=
APP_SPA_OIDC_CLIENT_ID=
