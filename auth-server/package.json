{
  "name": "better-auth-sso-provider",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:ui": "esbuild src/public/auth-ui.ts src/public/admin-ui.ts --bundle --format=iife --platform=browser --outdir=public",
    "db:migrate": "auth migrate --config src/auth.ts --yes",
    "bootstrap": "node --use-system-ca ./node_modules/tsx/dist/cli.mjs src/bootstrap.ts",
    "setup": "npm run build:ui && npm run db:migrate && npm run bootstrap",
    "dev": "npm run build:ui && node --use-system-ca ./node_modules/tsx/dist/cli.mjs watch src/server.ts",
    "start": "npm run build:ui && node --use-system-ca ./node_modules/tsx/dist/cli.mjs src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "latest",
    "better-auth": "latest",
    "dotenv": "latest",
    "express": "latest",
    "mysql2": "latest",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "@types/express": "latest",
    "@types/node": "latest",
    "@types/nodemailer": "^8.0.1",
    "auth": "latest",
    "esbuild": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
